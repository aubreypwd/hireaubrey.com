{
  "name": "@aubreypwd/11ty-starter",
  "version": "0.0.0",
  "description": "My starter setup for 11ty websites.",
  "keywords": [
    "11ty",
    "eleventy",
    "jamstack",
    "starter"
  ],
  "homepage": "https://github.com/aubreypwd/11ty-starter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aubreypwd/11ty-starter.git"
  },
  "license": "UNLICENSED",
  "author": "Aubrey Portwood",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "serve": "eleventy --serve",
    "live": "netlify dev --live local",
    "build": "eleventy",
    "postinstall": "npm run tools",
    "tools": "if [ -d ./11ty-tools/.git ]; then npm link ./11ty-tools; fi"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@aubreypwd/11ty-tools": "git+ssh://git@github.com:aubreypwd/11ty-tools.git",
    "@quasibit/eleventy-plugin-sitemap": "^2.2.0",
    "@sardine/eleventy-plugin-tinycss": "^2.0.0",
    "@sardine/eleventy-plugin-tinyhtml": "^0.2.0",
    "eleventy-google-fonts": "^0.1.0",
    "eleventy-plugin-automatic-noopener": "^2.0.2",
    "eleventy-plugin-gen-favicons": "^1.1.3",
    "eleventy-plugin-llms": "^0.1.0",
    "eleventy-plugin-metagen": "^1.8.3",
    "eleventy-plugin-robotstxt": "^1.0.2",
    "eleventy-sass": "^3.0.0-beta.0",
    "esbuild": "^0.27.3",
    "netlify-cli": "^24.0.1",
    "purgecss-from-html": "^8.0.0",
    "rimraf": "^6.1.3",
    "sanitize.css": "^13.0.0"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4"
  }
}
